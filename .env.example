# --- Connexion PostgreSQL Supabase (Direct Connection String pour SQLAlchemy) ---
# Format: postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres
DATABASE_URL=postgresql://postgres:ton-mot-de-passe-db@aws-0-eu-west-3.pooler.supabase.com:6543/postgres

# --- Supabase API (Client-side pour React Realtime) ---
VITE_SUPABASE_URL=https://ton-projet.supabase.co
VITE_SUPABASE_ANON_KEY=ton-anon-key-publishable

# --- Clé d'administration Supabase (Backend optionnel) ---
SUPABASE_SERVICE_ROLE_KEY=ton-service-role-key-admin

# --- Configurations WebAuthn ---
# RP_ID doit être le nom de domaine de l'application sans protocole ni port (ex: localhost en dev)
WEBAUTHN_RP_ID=localhost
# RP_NAME est le nom affiché de l'application dans les prompts système
WEBAUTHN_RP_NAME=Justalk
# ORIGIN doit être l'URL exacte de l'application frontend avec protocole et port
WEBAUTHN_ORIGIN=http://localhost:5173

# --- Sécurité ---
# Clé secrète de session longue et aléatoire pour signer les cookies JWT
JWT_SECRET=change-moi-en-une-longue-chaine-secrète-et-aléatoire-de-developpement
