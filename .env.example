# --- Firebase Client SDK (exposées au navigateur) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=justalk-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=justalk-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=justalk-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin SDK (serveur uniquement, jamais NEXT_PUBLIC_) ---
FIREBASE_PROJECT_ID=justalk-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@justalk-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=justalk-app.appspot.com

# --- Session JWT (cookie httpOnly de reconnexion auto) ---
JWT_SECRET=change-moi-en-une-longue-chaine-aleatoire

# --- WebAuthn ---
# RP_ID = domaine sans protocole ni port (ex: "justalk.app" ou "localhost" en dev)
WEBAUTHN_RP_ID=localhost
# ORIGIN = URL complète avec protocole (doit matcher exactement, https en prod)
WEBAUTHN_ORIGIN=http://localhost:3000
