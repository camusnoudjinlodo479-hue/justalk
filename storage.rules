rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Avatars et covers : lecture publique, écriture réservée à l'Admin SDK
    // (route /api/profile/create) afin de garder le contrôle sur la modération.
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    match /covers/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Médias de posts / stories : upload direct autorisé pour l'utilisateur
    // authentifié, dans son propre dossier uniquement.
    match /posts/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*|video/.*');
    }
    match /stories/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                    && request.resource.size < 15 * 1024 * 1024;
    }

    // Aucune image de visage brute n'est jamais uploadée : le traitement
    // face-api.js se fait 100% côté client et seul le hash quitte le navigateur.
  }
}
