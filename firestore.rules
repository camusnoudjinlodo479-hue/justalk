rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Utilisateurs ---
    // Le profil public est lisible par tous les utilisateurs connectés.
    // L'écriture passe exclusivement par les API routes (Admin SDK), donc
    // les écritures client directes sont interdites — sauf mise à jour de
    // son propre statut "online" pour Messenger.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['online', 'lastSeen']);
      allow create, delete: if false; // réservé à l'Admin SDK (register-verify)
    }

    // --- Empreintes biométriques (anti-doublon) ---
    // Jamais accessible côté client : ni lecture, ni écriture.
    match /biometricHashes/{docId} {
      allow read, write: if false;
    }

    // --- Posts (fil d'actualité) ---
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                     && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
                     && (
                          // l'auteur peut éditer son post
                          resource.data.authorId == request.auth.uid ||
                          // n'importe qui peut faire évoluer like/comment counters
                          request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['likes', 'commentsCount', 'shares'])
                        );
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                       && request.resource.data.authorId == request.auth.uid;
        allow delete: if request.auth != null
                       && resource.data.authorId == request.auth.uid;
      }
    }

    // --- Stories (expirent après 24h, suppression gérée par Cloud Function) ---
    match /stories/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                     && request.resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // --- Conversations Messenger ---
    match /conversations/{convId} {
      allow read, update: if request.auth != null
                            && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
                     && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        allow read: if request.auth != null
                     && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members;
        allow create: if request.auth != null
                       && request.resource.data.senderId == request.auth.uid
                       && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members;
        allow update, delete: if false;
      }
    }

    // --- Groupes / Pages ---
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                     && request.auth.uid in request.resource.data.members;
      allow update: if request.auth != null
                     && (
                          request.auth.uid in resource.data.moderators ||
                          // rejoindre : ajouter uniquement son propre uid à members
                          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
                           request.resource.data.members.size() == resource.data.members.size() + 1 &&
                           request.auth.uid in request.resource.data.members)
                        );
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    // --- Appels vidéo/audio (signalisation WebRTC) ---
    // Le document call et ses sous-collections de candidats ICE ne sont
    // accessibles qu'aux deux participants. Le flux média lui-même ne passe
    // jamais par Firestore (P2P direct), seules les métadonnées de connexion
    // (offer/answer/ICE) y transitent brièvement.
    match /calls/{callId} {
      allow read: if request.auth != null
                   && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUid;
      allow update: if request.auth != null
                     && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow delete: if request.auth != null
                     && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);

      match /{candidates}/{candidateId} {
        allow read, create: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.fromUid
              || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.toUid);
        allow update, delete: if false;
      }
    }

    // --- Notifications ---
    // Créées uniquement par les Cloud Functions (Admin SDK) suite à un
    // like/commentaire/demande d'ami. Le destinataire peut marquer comme lu.
    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.toUserId == request.auth.uid;
      allow update: if request.auth != null
                     && resource.data.toUserId == request.auth.uid
                     && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }
  }
}
